<form class="roll-card">
    <div class="card-title">
        {{label}}
    </div>
    {{> 'systems/mist-engine-fvtt/templates/chat/selected-tags-partial.hbs' positiveTags=positiveTags negativeTags=negativeTags}}
    <div class="roll-result">
        {{{diceRollHTML}}}
    </div>
    {{> 'systems/mist-engine-fvtt/templates/chat/critical-fumble-partial.hbs' isCritical=isCritical isFumble=isFumble}}
    <div class="consequence-container">
        {{#if (eq consequenceResult -1)}}
        <div class="consequence-result-negative">

            <span class="heading"><i class="consequence-result-icon negative"></i>6-</span>
            <p>{{{localize "MIST_ENGINE.MOVES.LEGEND.detailed.fail"}}}</p>
            <div class="power-counter">Power: {{numPowerTags}}</div>
        </div>
        {{/if}}
        {{#if (eq consequenceResult 0)}}
        <div class="consequence-result-neutral">
            <span class="heading"><i class="consequence-result-icon neutral"></i>7-9</span>
            <p>{{{localize "MIST_ENGINE.MOVES.LEGEND.detailed.neutral"}}}</p>
            <div class="power-counter">Power: {{numPowerTags}}</div>
        </div>
        {{/if}}
        {{#if (eq consequenceResult 1)}}
        <div class="consequence-result-positive">
            <span class="heading"><i class="consequence-result-icon positive"></i>10+</span>
            <p>{{{localize "MIST_ENGINE.MOVES.LEGEND.detailed.success"}}}</p>
            <div class="power-counter">Power: {{numPowerTags}}</div>
        </div>
        {{/if}}
    </div>

    {{#if canSpend}}
    <div class="detailed-spend">
        <div class="detailed-spend-header">
            <span>{{localize "MIST_ENGINE.DETAILED_SPEND.Title"}}</span>
            <span class="detailed-spend-remaining">{{remaining}} / {{total}}</span>
        </div>
        <div class="detailed-spend-options">
            {{#each options}}
            <button type="button" class="detailed-spend-btn" data-spend-option="{{this.id}}" {{#if this.disabled}}disabled{{/if}}>
                {{this.label}} <span class="detailed-spend-cost">{{#if (eq this.kind "status")}}+{{this.cost}}{{else}}{{this.cost}}{{/if}}</span>
            </button>
            {{/each}}
        </div>
        {{#if entries.length}}
        <ul class="detailed-spend-list">
            {{#each entries}}
            <li><i class="fa-solid fa-circle-xmark detailed-spend-undo" data-spend-undo="{{@index}}" title="{{localize 'MIST_ENGINE.DETAILED_SPEND.Undo'}}"></i> {{this.label}} <span class="detailed-spend-cost">({{this.cost}})</span></li>
            {{/each}}
        </ul>
        {{/if}}
    </div>
    {{/if}}
</form>
<section class="tab {{tabs.journey-consequences.id}} {{tabs.journey-consequences.cssClass}} scrollable"
    data-tab="{{tabs.journey-consequences.id}}" data-group="{{tabs.journey-consequences.group}}">
    {{#if editMode}}
    {{!-- Edit Mode Layout --}}
    <div class="flexcol gap-5">
        {{#each challenges}}
        {{> systems/mist-engine-fvtt/templates/actor/parts/challenge-partial.hbs challenge=this editMode=true}}
        {{/each}}
        <button data-action="createChallenge"><i class='fas fa-plus'></i>Add Challenge</button>
        {{#if (isCustomJSONImportEnabled true)}}
        <button data-action="importChallengeJSON"><i class="fas fa-file-import"></i>{{localize
            'MIST_ENGINE.ACTIONS.ImportShortChallengeVignetteJSON'}}</button>
        {{/if}}
    </div>
    {{else}}
    {{!-- Normal Layout --}}
    <div class="grid grid-2col">
        {{#each challenges}}
        {{> systems/mist-engine-fvtt/templates/actor/parts/challenge-partial.hbs challenge=this editMode=false}}
        {{/each}}
    </div>
    {{/if}}
</section>
<div>
    <header class="sheet-header {{#if system.editMode}}edit-mode{{else}}stylized-background{{/if}}">

        {{#if system.editMode}}

        <div class="header-fields">
            <img class="portrait-img" data-action="editImage" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"
                height="120" />
            <div class="col-character-name edit-mode">
                <h1 class="charname">
                    <input name="name" type="text" class="custom-font-color" value="{{actor.name}}"
                        placeholder="{{localize 'MIST_ENGINE.PLACEHOLDERS.Name'}}" />
                </h1>
                <div class="flexcol">
                    <div class="short-description"><input name="system.shortDescription" type="text"
                            class="custom-font-color" value="{{system.shortDescription}}"
                            placeholder="{{localize 'MIST_ENGINE.PLACEHOLDERS.ShortDescription'}}" /></div>
                </div>
                <div class="grid grid-4col">
                    <button data-action="clickedCustomBackground" class="change-custom-background-btn">{{localize
                        'MIST_ENGINE.LABELS.SelectCustomBackground'}}</button>
                    <button data-action="clickedCustomBackgroundEditor" class="change-custom-background-btn">{{localize
                        'MIST_ENGINE.LABELS.CustomBackgroundEditor.Button'}}</button>
                    <button data-action="clickedRemoveCustomBackground" class="change-custom-background-btn">{{localize
                        'MIST_ENGINE.LABELS.RemoveCustomBackground'}}</button>
                    <color-picker id="customFontColor" name="system.customFontColor"
                        value="{{system.customFontColor}}"></color-picker>
                </div>
            </div>
        </div>
        {{else}}
        <div class="header-fields">
            <div class="col-character-name">
                <div class="character-name-container">
                    <div class="title">
                        <h1 class="charname custom-font-color">{{actor.name}}
                            {{#if system.isOvercome}}<span class="overcome-badge" title="{{localize 'MIST_ENGINE.OVERCOME.HeroHint'}}">{{localize 'MIST_ENGINE.OVERCOME.Overcome'}}</span>{{/if}}
                        </h1>
                    </div>
                    <div class="short-description">{{system.shortDescription}}</div>
                </div>
            </div>
            <div class="col-main">
                <div class="flexcol">
                    <button data-action="clickRoll" class="roll-button" data-roll-type="quick"><i
                            class="fa-solid fa-dice"></i> {{localize 'MIST_ENGINE.ROLL_TYPES.quick'}}</button>
                    <button data-action="clickRoll" class="roll-button" data-roll-type="detailed"><i
                            class="fa-solid fa-dice"></i> {{localize 'MIST_ENGINE.ROLL_TYPES.detailed'}}</button>
                    <button data-action="clickRoll" class="roll-button" data-roll-type="reaction"><i
                            class="fa-solid fa-dice"></i> {{localize 'MIST_ENGINE.ROLL_TYPES.reaction'}}</button>
                    <button data-action="clickSacrificeRoll" class="roll-button"><i
                            class="fa-solid fa-heart-crack"></i> {{localize 'MIST_ENGINE.SACRIFICE.Title'}}</button>
                </div>
            </div>
            <div class="col-status">
                {{> 'systems/mist-engine-fvtt/templates/actor/parts/floating-tags-and-status-partial.hbs' useGrid=true
                classCustomContainer="floating-status-container-character"}}
            </div>
        </div>
        {{/if}}


    </header>

</div>
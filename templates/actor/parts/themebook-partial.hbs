<div class="themebook-container container-themebook-with-border" data-id="{{id}}" data-tab-category="{{themebook.system.tabCategory}}">
    <div class="themebook-style {{themebook.system.color}} flexcol">
        <div class="themebook-item" data-id="{{id}}" data-tab-category="{{themebook.system.tabCategory}}">
        <h2 class="theme-name">{{themebook.name}}
            {{#if editMode}}
            <a data-action="editItem" data-item-id='{{themebook._id}}'>
                <i class='fas fa-edit'></i>
            </a>
            <a data-action="deleteItem" data-item-id='{{themebook._id}}'>
                <i class='fas fa-trash'></i>
            </a>
            {{else}}
            <i class="themebook-icon {{themebook.system.type}}"></i>
            {{/if}}
        </h2>
        </div>
        {{#if editMode}}
            <div class="themekit-container">
                {{#if themebook.system.hasAssignedThemekit}}
                    <p>
                        <strong data-action="openThemekitCharacterApp" class="clickable" data-themebook-id="{{themebook._id}}">{{themebook.system.themekit.name}} <i class="fa-solid fa-circle-arrow-up"></i></strong>
                        <strong><i class="fa-solid fa-trash clickable" data-action="removeThemekit" data-themebook-id="{{themebook._id}}"></i></strong>
                    </p>
                {{else}}
                    <button class="themekit-button" data-action="openThemekitSelection" data-themebook-id="{{themebook._id}}">{{localize "MIST_ENGINE.THEMEKITS.SelectThemekit"}}</button>
                {{/if}}
           </div>
        {{/if}}
        <div class="powertags-container">
            
            {{#if editMode}}
            <div class="themebook-icon-line">
                <i class="fas fa-plus add-line-icon clickable" data-action="addEmptyPowertag" data-item-id="{{themebook._id}}" title="{{localize "MIST_ENGINE.LABELS.AddPowertag"}}"></i> {{localize "MIST_ENGINE.LABELS.AddPowertag"}} 
            </div>
            {{/if}}
            {{#each themebook.system.powertags as |powertag index|}}
            {{> "systems/mist-engine-fvtt/templates/shared/litm/themebook-powertag-line.hbs" index=index id=../themebook._id
            powertag=powertag editMode=../editMode tidyTags=../tidyTags}}
            {{/each}}

            {{#if editMode}}
            <div class="themebook-icon-line">
                <i class="fas fa-plus add-line-icon clickable" data-action="addEmptyWeaknessTag" data-item-id="{{themebook._id}}" title="{{localize "MIST_ENGINE.LABELS.AddWeaknesstag"}}"></i> {{localize "MIST_ENGINE.LABELS.AddWeaknesstag"}} 
            </div>
            {{/if}}
            {{#each themebook.system.weaknesstags as |weaknesstag index|}}
            {{> "systems/mist-engine-fvtt/templates/shared/litm/themebook-weakness-line.hbs" index=index id=../themebook._id      weaknesstag=weaknesstag editMode=../editMode tidyTags=../tidyTags}}
            {{/each}}

            {{#if themebook.system.hasSpecialImprovements}}
            <h3 class="special-improvement-section-label">{{localize 'MIST_ENGINE.LABELS.SpecialImprovements'}}</h3>
            {{/if}}
            {{#each themebook.system.specialImprovements as |specialImprovement index|}}
            {{#if (notEmpty specialImprovement.name)}}
            {{> "systems/mist-engine-fvtt/templates/shared/litm/themebook-special-improvement-line.hbs" index=index
            id=../themebook._id
            specialImprovement=specialImprovement editMode=../editMode}}
            {{/if}}
            {{/each}}

        </div>
        <div class="quest-container">
            {{#if editMode}}
            <textarea class="item-editable-stat quest-textarea" data-item-id={{themebook._id}}
                data-item-stat="system.quest"
                placeholder="{{localize 'MIST_ENGINE.PLACEHOLDERS.QuestGoal'}}">{{themebook.system.quest}}</textarea>
            <textarea class="item-editable-stat quest-textarea" data-item-id={{themebook._id}}
                data-item-stat="system.story"
                placeholder="{{localize 'MIST_ENGINE.PLACEHOLDERS.ThemebookStory'}}">{{themebook.system.story}}</textarea>
            {{else}}
            <h3>{{localize 'MIST_ENGINE.LABELS.Quest'}}</h3>
            <p class="quest-text" data-tooltip="{{themebook.system.story}}" data-tooltip-direction="DOWN">{{themebook.system.quest}}</p>
            {{/if}}
        </div>
        <div class="development-container flexrow">
            {{> "systems/mist-engine-fvtt/templates/actor/parts/development-partial.hbs" name=(localize
            'MIST_ENGINE.LABELS.Abandon') id=themebook._id key="system.abandon" value=themebook.system.abandon}}
            {{> "systems/mist-engine-fvtt/templates/actor/parts/development-partial.hbs" name=(localize
            'MIST_ENGINE.LABELS.Improve') id=themebook._id key="system.improve" value=themebook.system.improve}}
            {{> "systems/mist-engine-fvtt/templates/actor/parts/development-partial.hbs" name=(localize
            'MIST_ENGINE.LABELS.Milestone') id=themebook._id key="system.milestone" value=themebook.system.milestone}}
        </div>
    </div>
</div>
<form class="roll-dialog-container scrollable">
    {{#if waitingForGm}}
    <div class="gm-confirm-waiting" style="display:flex; flex-direction:column; gap:8px; align-items:center; padding:8px; border:1px dashed var(--color-border-dark, #666); border-radius:4px; margin-bottom:8px;">
        <span><i class="fa-solid fa-hourglass-half"></i> {{localize "MIST_ENGINE.GM_CONFIRM.WaitingForGm"}}</span>
        <button type="button" data-action="clickCancelConfirmation">{{localize "MIST_ENGINE.GM_CONFIRM.Cancel"}}</button>
    </div>
    {{/if}}
    <div {{#if waitingForGm}}style="pointer-events:none; opacity:0.5;"{{/if}}>
    {{!-- Selected Tags --}}
    <div class="selected-tags-container flexcol">
        <label class="resource-label">You selected:</label>
        {{#each selectedTags}}
        <div class="selected-tag tag {{#if this.positive}}positive{{else}}negative{{/if}} {{#unless this.isAppliedInPreview}}unapplied-preview{{/unless}} {{#if this.isStatus}}status{{/if}} {{#if this.isClickable}}clickable{{/if}}" {{#if this.isClickable}}data-action="clickTagStatusModifierToggle" data-index="{{this.index}}"{{/if}}>
            <span class="tag-icon">
                {{#if this.positive}}<i class="fa-solid fa-thumbs-up"></i>{{else}}<i
                    class="fa-solid fa-thumbs-down"></i>{{/if}}
            </span>
            {{#if this.might}}<i class="might-icon {{this.mightIcon}}"></i>{{/if}}
            {{#if this.toBurn}}🔥
            {{/if}}{{this.name}}{{#if (gt this.value 0)}}-{{this.value}}{{/if}}
            <span class="deselect-icon">
                <i class="fa-solid fa-circle-trash" data-action="clickDeselectTag" data-index="{{@index}}"></i>
            </span>
        </div>
        {{/each}}
    </div>
    {{!-- Story Tags --}}
    <div class="selected-tags-container flexcol">
        <label class="resource-label">Story Tags / Status selected:</label>
        {{#each selectedStoryTags}}
        <div class="tag {{#if this.positive}}positive{{else}}negative{{/if}} {{#unless this.isAppliedInPreview}}unapplied-preview{{/unless}}">
            <span class="tag-icon">
                {{#if this.positive}}<i class="fa-solid fa-thumbs-up"></i>{{else}}<i
                    class="fa-solid fa-thumbs-down"></i>{{/if}}
            </span>
            {{#if this.might}}<i class="might-icon {{this.mightIcon}}"></i>{{/if}}
            {{#if this.toBurn}}🔥{{/if}}{{this.name}}{{#if (gt
            this.value 0)}}-{{this.value}}{{/if}}
        </div>
        {{/each}}
    </div>
    {{!-- Challenge Tags --}}
     <div class="selected-tags-container flexcol">
        <label class="resource-label">Challenge Tags / Status selected:</label>
        {{#each challengeTags}}
        <div class="tag {{#if this.positive}}positive{{else}}negative{{/if}} {{#unless this.isAppliedInPreview}}unapplied-preview{{/unless}}">
            <span class="tag-icon">
                {{#if this.positive}}<i class="fa-solid fa-thumbs-up"></i>{{else}}<i
                    class="fa-solid fa-thumbs-down"></i>{{/if}}
            </span>
            {{#if this.might}}
                <img src="systems/mist-engine-fvtt/assets/icons/icon-sword.svg" alt="Might Icon" class="might-icon">
            {{/if}}
            {{#if this.toBurn}}🔥{{/if}}{{this.name}}{{#if (gt
            this.value 0)}}-{{this.value}}{{/if}}
        </div>
        {{/each}}
    </div>
    {{!-- GM Tags --}}
    <div class="selected-tags-container flexcol">
        {{#each selectedGmTags}}
        <div class="tag {{#if this.positive}}positive{{else}}negative{{/if}} {{#unless this.isAppliedInPreview}}unapplied-preview{{/unless}}">
            <span class="tag-icon">
                {{#if this.positive}}<i class="fa-solid fa-thumbs-up"></i>{{else}}<i
                    class="fa-solid fa-thumbs-down"></i>{{/if}}
            </span>
            {{#if this.might}}<i class="might-icon {{this.mightIcon}}"></i>{{/if}}
            {{#if this.toBurn}}🔥{{/if}}{{this.name}}{{#if (gt
            this.value 0)}}-{{this.value}}{{/if}}
        </div>
        {{/each}}
    </div>
    {{!-- Positive & Negative Mods --}}
    <div class="form-group">
        <label class="resource-label">Positive Mods:</label>
        <div class="flexrow">
            <i class="fa-solid fa-minus icon-hover" style="text-align:center" id="button-positive-minus"
                data-action="clickModPositiveMinus"></i>
            <input type="number" name="positiveValue" value="{{numModPositive}}" data-dtype="Number"
                id="positiveInput" />
            <i class="fa-solid fa-plus icon-hover" style="text-align:center" id="button-positive-plus"
                data-action="clickModPositivePlus"></i>
        </div>
    </div>
    <div class="form-group">
        <label class="resource-label">Negative Mods:</label>
        <div class="flexrow">
            <i class="fa-solid fa-minus icon-hover" style="text-align:center" id="button-negative-minus"
                data-action="clickModNegativeMinus"></i>
            <input type="number" name="negativeValue" value="{{numModNegative}}" data-dtype="Number"
                id="negativeInput" />
            <i class="fa-solid fa-plus icon-hover" style="text-align:center" id="button-negative-plus"
                data-action="clickModNegativePlus"></i>
        </div>
    </div>
    {{!-- Might --}}
    {{#if mightUsageEnabled}}
    {{> "systems/mist-engine-fvtt/templates/dice-roll-app/might.hbs"}}
    {{/if}}
    <div class="mt-10">
        <div class="form-group">
            <label class="resource-label power-label">Power: {{powerAmount}}</label>
        </div>
    </div>
    <footer class="dialog-footer">
        <button type="button" class="roll-button" data-action="clickedRoll" {{#if waitingForGm}}disabled{{/if}}>Roll</button>
    </footer>
    </div>
</form>
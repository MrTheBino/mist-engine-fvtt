<div class="item-powertag-line flexrow">
    <strong style="flex-grow:0.3;">{{questionIndexToLetter index}}</strong>
    <input type="checkbox" name="system.powertags.{{index}}.planned" style="flex-grow:0.3;" title="{{localize "MIST_ENGINE.HELP.Titles.PlannedPowertag"}}"  {{#if powertag.planned}}checked{{/if}}/>
    <input type="checkbox" name="system.powertags.{{index}}.burned" {{#if powertag.burned}}checked{{/if}} style="display: none;"/>
    <div style="flex-grow:8;">
     <input type="text" name="system.powertags.{{index}}.question" value="{{powertag.question}}" title="{{questionIndexToLetter index}} - Question" placeholder="{{powerTagQuestionPlaceholder index powertag.question}}"/>
     <input type="text" name="system.powertags.{{index}}.name" value="{{powertag.name}}" title="{{questionIndexToLetter index}} - Tag" placeholder="Answer / The Tag" />
     </div>
    <i class="fa-solid fa-trash clickable" data-action="deletePowertag" data-index="{{index}}" style="flex-grow:0.3; margin-left: 0.5em;" title="{{localize "MIST_ENGINE.HELP.DeletePowertag"}}"></i>
</div>
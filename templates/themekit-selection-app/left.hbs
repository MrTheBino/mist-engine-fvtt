<div class="left-panel scrollable">
    {{#if hasThemebookFilter}}
    <div class="themekit-filter-banner">
        {{#if isFilteredByThemebook}}
        <span>{{localize "MIST_ENGINE.THEMEKITS.FilteredForThemebook" themebook=themebookFilterLabel}}</span>
        <a class="themekit-filter-toggle" data-action="toggleShowAllThemekits">{{localize "MIST_ENGINE.THEMEKITS.ShowAllThemekits"}}</a>
        {{else}}
        <span>{{localize "MIST_ENGINE.THEMEKITS.ShowingAllThemekits"}}</span>
        <a class="themekit-filter-toggle" data-action="toggleShowAllThemekits">{{localize "MIST_ENGINE.THEMEKITS.ShowFilteredThemekits" themebook=themebookFilterLabel}}</a>
        {{/if}}
    </div>
    {{/if}}
    <input type="text" class="themekit-search" placeholder="Search themekits...">
    <div class="search-filters">
        <label class="search-filter-toggle"><input type="checkbox" data-filter="powertags"> Power Tags</label>
        <label class="search-filter-toggle"><input type="checkbox" data-filter="weaknesstags"> Weakness Tags</label>
        <label class="search-filter-toggle"><input type="checkbox" data-filter="specialimprovements"> Special Improvements</label>
        <label class="search-filter-toggle"><input type="checkbox" data-filter="quest"> Quest</label>
        <label class="search-filter-toggle"><input type="checkbox" data-filter="story"> Story</label>
    </div>

            <!-- we list all available themekits , group first, then their children -->
            {{#each availableThemekits}}
            <div class="themekit-group">
                <div class="group-header">{{this.groupName}}</div>
                <ul>
                    {{#each this.themekits}}
                    <li
                        data-search-powertags="{{#each this.themekit.system.powertags}}{{this.name}} {{/each}}"
                        data-search-weaknesstags="{{#each this.themekit.system.weaknesstags}}{{this.name}} {{/each}}"
                        data-search-specialimprovements="{{#each this.themekit.system.specialImprovements}}{{this.name}} {{/each}}"
                        data-search-quest="{{this.themekit.system.quest}}"
                        data-search-story="{{this.themekit.system.story}}"
                    >
                        {{#if this.isCompendium}}
                        <i class="fa-solid fa-book source-icon" title="Compendium"></i>
                        {{else}}
                        <i class="fa-solid fa-globe source-icon" title="World"></i>
                        {{/if}}
                        <a class="themekit-button" data-themekit-uuid="{{this.themekit.uuid}}" data-action="selectThemekit">
                            {{this.themekit.name}}
                        </a>
                    </li>
                    {{/each}}
                </ul>
            </div>
            {{/each}}
    </div>

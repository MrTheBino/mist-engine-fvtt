<div class="item-storytag-line flexrow">
    {{#if editMode}}
    <input type="checkbox" class="storytag-item-editable" data-item-id="{{id}}" data-index="{{index}}" data-key="{{key}}" data-source="{{source}}" data-sub-key="planned"
        {{#if storytag.planned}}checked{{/if}} title="{{localize "MIST_ENGINE.HELP.Titles.PlannedStorytag"}}" style="flex-grow:0.3; margin-right: 0.5em;"/>
    <input type="text" class="storytag-item-editable" data-item-id='{{id}}' data-index="{{index}}" value="{{this.name}}" data-key="{{key}}" placeholder="{{localize 'MIST_ENGINE.PLACEHOLDERS.Name'}}"/>
    <a class="themebook-icon" data-action="deleteStoryTag" data-item-id='{{id}}' data-index="{{index}}" data-source="{{source}}" data-key="{{key}}">
        <i class='fas fa-trash'></i>
    </a>
    {{else}}
        {{#unless storytag.planned}}
        <span class="burn-indicator" data-action="toggleStoryTagBurn" data-item-id="{{id}}" data-index="{{index}}" data-key="{{key}}" data-source="{{source}}">
                <i class="burn-icon {{#if storytag.toBurn}}to-burn{{/if}}"></i>
            </span>
            <span class="litm-pc-storytag storytag-name storytag-selectable {{#if firstTag}}first{{/if}} {{#if storytag.selected}}selected{{/if}} {{#if storytag.burned}}burned{{/if}} {{#if storytag.expired}}expired{{/if}} {{#if storytag.expiring}}expiring{{/if}}" title="{{localize "MIST_ENGINE.HELP.Titles.RightClickToToggleBurnState"}}"
                data-action="toggleStoryTagSelection" data-index="{{index}}" data-item-id="{{id}}" data-key="{{key}}" data-source="{{source}}" {{{storyTagDraggableData storytag source}}}>{{#if storytag.expiring}}<i class="fa-solid fa-hourglass-half"></i> {{/if}}{{storytag.name}}</span>
        {{else}}
            {{#unless tidyTags}}
                <span class="burn-indicator"></span>
                <span class="litm-pc-storytag storytag-name empty">{{storytag.name}}</span>
            {{/unless}}
        {{/unless}}
    {{/if}}
</div>
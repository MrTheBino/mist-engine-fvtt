<div class="item-weakness-line flexrow">
    {{#if editMode}}
    <strong style="flex-grow:0.3;" class="letter-box">{{questionIndexToLetter index}}</strong>
    <input type="checkbox" class="themebook-entry-input" data-item-id="{{id}}" data-array="system.weaknesstags" data-index="{{index}}" data-key="planned" data-source="{{source}}"
    {{#if weaknesstag.planned}}checked{{/if}} title="{{localize "MIST_ENGINE.HELP.Titles.PlannedPowertag"}}" style="flex-grow:0.3; margin-right: 0.5em;"/>
    <input class="themebook-entry-input" data-item-id="{{id}}" type="text" data-array="system.weaknesstags" data-index="{{index}}" data-key="name"
        value="{{weaknesstag.name}}" placeholder="{{weaknessTagQuestionPlaceholder index weaknesstag.question}}" title="{{weaknessTagQuestionPlaceholder index weaknesstag.question}}" title="Weakness" data-source="{{source}}" style="flex-grow:8;"/>
    <i class="fa-solid fa-trash clickable" data-action="deleteWeaknessTag" data-index="{{index}}" data-item-id="{{id}}" data-source="{{source}}" style="flex-grow:0.3; margin-left: 0.5em;" title="{{localize "MIST_ENGINE.HELP.DeleteWeaknessTag"}}"></i>
    {{else}}
        {{#if (tagFilledAndNotPlanned weaknesstag)}}
        <span class="weakness-indicator"><i class="fa-light fa-angles-down"></i></span>
        <span class="litm-pc-weakness wt-selectable {{#if weaknesstag.selected}}selected{{/if}}"
            data-weaknesstag-index="{{index}}" data-item-id="{{id}}" data-source="{{source}}">
            
            {{weaknesstag.name}}
        </span>
        {{/if}}
    {{/if}}
</div>